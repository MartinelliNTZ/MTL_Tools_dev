{
    "chat.tools.terminal.autoApprove": {
        "Test-Path": true,
        "Get-Item": true,
        "ForEach-Object": true,
        "Move-Item": true,
        "/^python -m py_compile processing/attribute_statistics\\.py$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^python -m py_compile processing/FolderLayerProcessor\\.py processing/provider\\.py$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^python -m py_compile processing/RasterDifferenceStatiscs\\.py$/": {
            "approve": true,
            "matchCommandLine": true
        }
    },
    "chat.agent.maxRequests": 150,
    "chat.agent.enabled": true,
    "python-envs.defaultEnvManager": "ms-python.python:conda",
    "python-envs.defaultPackageManager": "ms-python.python:conda"
}